# ============================================
# AI Novel Writing Assistant - Production Config
# ============================================
# 复制此文件为 .env，然后填入你的 API Key
# cp .env.production .env
#
# 必填项：至少填写一个 LLM API Key
# ============================================

# Server
PORT=3000
HOST=0.0.0.0
ALLOW_LAN=true
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=file:./data/dev.db

# ============================================
# Authentication（可选，留空则不需要登录）
# ============================================
AUTH_PASSWORD=
TOKEN_SECRET=

# ============================================
# LLM Provider（必填，至少一个）
# ============================================

# --- OpenAI（推荐）---
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- DeepSeek（性价比高）---
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat

# --- 硅基流动（国内可用）---
# SILICONFLOW_API_KEY=your-sf-key
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

# ============================================
# RAG（可选，默认禁用以简化部署）
# ============================================
# RAG_ENABLED=true    # 启用前需先开启 qdrant 服务
# QDRANT_URL=http://qdrant:6333

# ============================================
# Client
# ============================================
# VITE_API_BASE_URL is not needed in production (uses relative /api path)
